{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ingot Agent",
  "version": "0.1.0",
  "identifier": "com.ingotstack.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ingot Agent",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Governed connector code generation for Ingot",
    "longDescription": "Ingot Agent generates, builds, tests, approves, and packages production data connectors through the governed Central Agent API.",
    "copyright": "Copyright © Ingot Contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

