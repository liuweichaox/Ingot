{
  "Urls": "http://localhost:8000",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Platform": {
    "DatabasePath": "Data/platform.db"
  },
  "ConnectionStrings": {
    "Events": ""
  },
  "EventIngest": {
    "RequireToken": true,
    "EdgeTokens": {},
    "MaxFutureSkewMinutes": 60,
    "MaxPastDays": 3650,
    "ChunkTimeInterval": "30 days",
    "RetentionDays": 0,
    "CompressAfterDays": 0
  },
  "InspectionSubmission": {
    "RequireToken": true,
    "UserTokens": {}
  },
  "Chat": {
    "DatabasePath": "Data/chat.db",
    "Enabled": false,
    "Provider": "Deterministic",
    "FastModel": "deterministic-v1",
    "ReasoningModel": "deterministic-v1",
    "MaxToolCalls": 8,
    "MaxRunSeconds": 60,
    "EnableCombinedAnalysis": false,
    "MaxDiscussionRounds": 3,
    "MaxDiscussionTurns": 9,
    "RequireToken": true,
    "UserTokens": {},
    "ModelPricing": {}
  },
  "ChatDataAccess": {
    "Users": {
      "operator": {
        "AllowAll": true,
        "EdgeIds": []
      }
    }
  },
  "Webhook": {
    "Enabled": true,
    "PollIntervalMs": 1000,
    "BatchSize": 100,
    "RequestTimeoutSeconds": 15,
    "EventTypePrefix": "com.ingot"
  },
  "Frontend": {
    "BaseUrl": ""
  },
  "AllowedHosts": "*"
}
