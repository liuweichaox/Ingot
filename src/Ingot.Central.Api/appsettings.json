{
  "Urls": "http://localhost:8000",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Central": {
    "DatabasePath": "Data/central.db"
  },
  "ConnectionStrings": {
    "Events": "Host=localhost;Port=5432;Database=ingot;Username=ingot;Password=ingot"
  },
  "EventIngest": {
    "RequireToken": true,
    "EdgeTokens": {
      "EDGE-001": "change-me-edge-001"
    }
  },
  "Webhook": {
    "Enabled": true,
    "PollIntervalMs": 1000,
    "BatchSize": 100,
    "RequestTimeoutSeconds": 15,
    "EventTypePrefix": "com.ingot"
  },
  "Frontend": {
    "BaseUrl": ""
  },
  "AllowedHosts": "*"
}
