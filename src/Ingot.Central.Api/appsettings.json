{
  "Urls": "http://localhost:8000",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Central": {
    "DatabasePath": "Data/central.db"
  },
  "ConnectionStrings": {
    "Events": ""
  },
  "EventIngest": {
    "RequireToken": true,
    "EdgeTokens": {}
  },
  "InspectionSubmission": {
    "RequireToken": true,
    "ActorTokens": {}
  },
  "Chat": {
    "DatabasePath": "Data/chat.db",
    "Enabled": false,
    "Provider": "Deterministic",
    "FastModel": "deterministic-v1",
    "ReasoningModel": "deterministic-v1",
    "MaxToolCalls": 8,
    "MaxRunSeconds": 60,
    "EnableDeepInvestigation": false,
    "MaxDiscussionRounds": 3,
    "MaxDiscussionTurns": 9,
    "RequireToken": true,
    "ActorTokens": {},
    "ModelPricing": {}
  },
  "ChatDataAccess": {
    "Actors": {
      "operator": {
        "AllowAll": true,
        "EdgeIds": []
      }
    }
  },
  "Webhook": {
    "Enabled": true,
    "PollIntervalMs": 1000,
    "BatchSize": 100,
    "RequestTimeoutSeconds": 15,
    "EventTypePrefix": "com.ingot"
  },
  "Frontend": {
    "BaseUrl": ""
  },
  "AllowedHosts": "*"
}
