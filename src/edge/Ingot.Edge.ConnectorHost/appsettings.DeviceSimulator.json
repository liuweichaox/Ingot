{
  "Urls": "http://127.0.0.1:8001",
  "Logging": {
    "DatabasePath": "../../../../../../.codex-temp/device-acquisition/logs.db",
    "RetentionDays": 7
  },
  "Context": {
    "DatabasePath": "../../../../../../.codex-temp/device-acquisition/context.db"
  },
  "Events": {
    "DatabasePath": "../../../../../../.codex-temp/device-acquisition/events.db",
    "RetentionDays": 7,
    "CleanupIntervalSeconds": 3600,
    "MaxBacklogRows": 100000
  },
  "Edge": {
    "EnablePlatformReporting": true,
    "PlatformApiBaseUrl": "http://127.0.0.1:8000",
    "PublicBaseUrl": "http://127.0.0.1:8001",
    "EnableEventShipping": true,
    "EventIngestToken": "development-device-simulator-token-0001",
    "EventBatchSize": 500,
    "EventIdleDelayMs": 500,
    "EdgeId": "EDGE-DEMO-001"
  },
  "Acquisition": {
    "Enabled": true,
    "DeviceBaseUrl": "http://127.0.0.1:8100",
    "SnapshotPath": "/api/v1/snapshot",
    "PollIntervalMs": 1000,
    "Source": "connector/http-polling/FURNACE-001",
    "SubjectType": "equipment",
    "SubjectId": "FURNACE-001",
    "TimestampPath": "timestamp",
    "SequencePath": "sequence",
    "SampleEventType": "process.sample",
    "StaticContext": {
      "process_type": "continuous-heat-treatment"
    },
    "ContextFields": [
      { "SourcePath": "productSeries", "Key": "product_series", "Required": true },
      { "SourcePath": "operatingState", "Key": "operating_state", "Required": true }
    ],
    "Fields": [
      { "SourcePath": "sensors.炉温℃", "Code": "furnace.temperature", "DataType": "double", "Required": true },
      { "SourcePath": "sensors.设定温度℃", "Code": "furnace.temperature_setpoint", "DataType": "double", "Required": true },
      { "SourcePath": "sensors.炉压kPa", "Code": "furnace.pressure", "DataType": "double", "Required": true },
      { "SourcePath": "sensors.氧含量ppm", "Code": "atmosphere.oxygen", "DataType": "double", "Required": true },
      { "SourcePath": "sensors.风机转速rpm", "Code": "fan.speed", "DataType": "integer", "Required": true },
      { "SourcePath": "sensors.加热器开启", "Code": "heater.enabled", "DataType": "boolean", "Required": true },
      { "SourcePath": "sensors.运行模式", "Code": "operation.mode", "DataType": "string", "Required": true }
    ],
    "Recipe": {
      "EventType": "recipe.applied",
      "IdPath": "activeRecipe.id",
      "VersionPath": "activeRecipe.version",
      "NamePath": "activeRecipe.name",
      "ParametersPath": "activeRecipe.parameters",
      "ParameterFields": [
        { "SourcePath": "目标温度℃", "Code": "temperature.target", "DataType": "double", "Required": true },
        { "SourcePath": "保温时间min", "Code": "soak.duration", "DataType": "integer", "Required": true },
        { "SourcePath": "保护气启用", "Code": "protective_gas.enabled", "DataType": "boolean", "Required": true },
        { "SourcePath": "工艺模式", "Code": "process.mode", "DataType": "string", "Required": true }
      ]
    }
  }
}
