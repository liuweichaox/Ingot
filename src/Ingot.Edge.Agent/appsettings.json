{
  "Urls": "http://+:8001",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "DatabasePath": "Data/logs.db",
    "RetentionDays": 30
  },
  "AllowedHosts": "*",
  "InfluxDB": {
    "Url": "http://localhost:8086",
    "Token": "your-influxdb-token",
    "Bucket": "iot",
    "Org": "default"
  },
  "Edge": {
    "EnableCentralReporting": true,
    "CentralApiBaseUrl": "http://localhost:8000",
    "EdgeId": "EDGE-001",
    "HeartbeatIntervalSeconds": 10,
    "EnableEventShipping": true,
    "EventIngestToken": "change-me-edge-001",
    "EventBatchSize": 500,
    "EventIdleDelayMs": 1000,
    "EventRetryMaxSeconds": 60
  },
  "Events": {
    "DatabasePath": "Data/events.db",
    "RetentionDays": 7,
    "CleanupIntervalSeconds": 3600,
    "MaxBacklogRows": 500000,
    "EnableInfluxProjection": true
  },
  "Profiles": {
    "Directory": "Profiles"
  },
  "Acquisition": {
    "ChannelCollector": {
      "ConnectionCheckRetryDelayMs": 100,
      "TriggerWaitDelayMs": 100
    },
    "QueueService": {
      "FlushIntervalSeconds": 5
    },
    "DeviceConfigService": {
      "ConfigDirectory": "Configs",
      "ConfigChangeDetectionDelayMs": 500
    },
    "StateStore": {
      "DatabasePath": "Data/acquisition-state.db"
    }
  }
}
