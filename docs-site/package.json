{
  "name": "ingot-docs-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.13.0" },
  "scripts": {
    "prepare-content": "node scripts/prepare-content.mjs",
    "dev": "npm run prepare-content && next dev --webpack",
    "build": "npm run prepare-content && next build --webpack",
    "test": "npm run build && node --test tests/export.test.mjs",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern out"
  },
  "dependencies": {
    "github-slugger": "2.0.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "7.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-slug": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.10",
    "typescript": "7.0.2"
  },
  "overrides": { "postcss": "8.5.10" }
}
