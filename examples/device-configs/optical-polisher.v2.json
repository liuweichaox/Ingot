{
  "SchemaVersion": 2,
  "IsEnabled": true,
  "SourceCode": "POL-03-PLC",
  "Adapter": "plc",
  "Profile": "optical",
  "Asset": {
    "Type": "polishing-machine",
    "Id": "POL-03"
  },
  "Driver": "melsec-mc",
  "Host": "192.168.10.33",
  "Port": 6000,
  "ProtocolOptions": {
    "connect-timeout-ms": "5000",
    "receive-timeout-ms": "5000"
  },
  "HeartbeatMonitorRegister": "D100",
  "HeartbeatPollingInterval": 5000,
  "Channels": [
    {
      "Measurement": "polishing_telemetry",
      "ChannelCode": "telemetry",
      "EnableBatchRead": false,
      "BatchReadLength": 0,
      "BatchSize": 10,
      "AcquisitionInterval": 1000,
      "AcquisitionMode": "Always",
      "Metrics": [
        {
          "MetricLabel": "pressure",
          "FieldName": "pressure",
          "Register": "D6001",
          "Index": 0,
          "DataType": "short",
          "EvalExpression": "value / 100.0"
        }
      ]
    }
  ],
  "EventRules": [
    {
      "RuleId": "polish-cycle",
      "Category": "cycle",
      "Subject": {
        "Type": "polishing-machine",
        "Id": "POL-03"
      },
      "ContextKeys": [
        "material_lot",
        "tooling"
      ],
      "SnapshotOnStart": [
        {
          "FieldName": "recipe_id",
          "Tag": "D6100",
          "DataType": "string",
          "StringByteLength": 16
        }
      ],
      "SnapshotOnEnd": [
        {
          "FieldName": "good_count",
          "Tag": "D6110",
          "DataType": "ushort"
        }
      ],
      "Trigger": {
        "Kind": "EdgePair",
        "Tag": "D6006",
        "DataType": "short",
        "StartTriggerMode": "RisingEdge",
        "EndTriggerMode": "FallingEdge"
      }
    },
    {
      "RuleId": "lot-change",
      "Category": "material",
      "EventType": "material.lot_changed",
      "Subject": {
        "Type": "polishing-machine",
        "Id": "POL-03"
      },
      "ContextKeys": [
        "material_lot"
      ],
      "SetContext": {
        "material_lot": "$value"
      },
      "Trigger": {
        "Kind": "ValueChanged",
        "Tag": "D6200",
        "DataType": "string",
        "StringByteLength": 20
      }
    },
    {
      "RuleId": "tooling-change",
      "Category": "tooling",
      "EventType": "tooling.changed",
      "Subject": {
        "Type": "polishing-machine",
        "Id": "POL-03"
      },
      "ContextKeys": [
        "material_lot",
        "tooling"
      ],
      "SetContext": {
        "tooling": "$value"
      },
      "Trigger": {
        "Kind": "ValueChanged",
        "Tag": "D6300",
        "DataType": "string",
        "StringByteLength": 12
      }
    }
  ]
}
