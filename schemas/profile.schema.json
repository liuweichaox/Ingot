{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuweichaox/Ingot/schemas/profile.schema.json",
  "title": "Ingot Industry Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["SchemaVersion", "Name", "ObjectTypes", "EventTypes"],
  "properties": {
    "SchemaVersion": {
      "type": "integer",
      "const": 1
    },
    "Name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "Description": {
      "type": "string"
    },
    "ObjectTypes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.-]*$"
      }
    },
    "EventTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["Type"],
        "properties": {
          "Type": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "RequiredContext": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
