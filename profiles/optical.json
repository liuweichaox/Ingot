{
  "SchemaVersion": 1,
  "Name": "optical",
  "Description": "光学加工场景的最小事件语言。",
  "ObjectTypes": [
    "equipment",
    "polishing-machine",
    "coating-machine",
    "inspection-station"
  ],
  "EventTypes": [
    {
      "Type": "cycle.started",
      "RequiredContext": ["material_lot", "tooling"]
    },
    {
      "Type": "cycle.completed",
      "RequiredContext": ["material_lot", "tooling"]
    },
    {
      "Type": "alarm.raised",
      "RequiredContext": ["material_lot"]
    },
    {
      "Type": "alarm.cleared",
      "RequiredContext": ["material_lot"]
    },
    {
      "Type": "material.lot_changed",
      "RequiredContext": ["material_lot"]
    },
    {
      "Type": "tooling.changed",
      "RequiredContext": ["material_lot", "tooling"]
    }
  ]
}
